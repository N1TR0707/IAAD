# ====== KONFIGURASI PRODUKSI BACKEND ======
# Salin file ini menjadi .env di server, lalu sesuaikan nilainya.
# PENTING: ganti semua nilai rahasia di bawah!

# Environment
NODE_ENV=production

# Server
PORT=5000
# Domain frontend Anda (untuk CORS). Ganti dengan domain asli.
CLIENT_URL=https://iaadproject.com

# Database - SQLite (file permanen di server)
DB_DIALECT=sqlite
# Path absolut file database di server. Pastikan folder-nya ada & bisa ditulis.
DB_STORAGE=/var/www/iaad/database/tokopedia.sqlite

# JWT - WAJIB ganti dengan string acak panjang & rahasia!
# Bisa generate dengan: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_STRING_ACAK_PANJANG_DAN_RAHASIA
JWT_EXPIRE=7d

# Akun pemilik (dibuat otomatis saat pertama jalan). WAJIB ganti!
OWNER_EMAIL=admin@iaadproject.com
OWNER_PASSWORD=GANTI_PASSWORD_KUAT_DI_SINI

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
